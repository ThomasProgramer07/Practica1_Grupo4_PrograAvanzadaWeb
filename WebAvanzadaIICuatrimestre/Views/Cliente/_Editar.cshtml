@model WebAvanzadaIICuatrimestre.BLL.Dtos.ClienteDto

<div class="modal fade" id="modalEditarCliente" tabindex="-1" aria-labelledby="modalEditarCliente" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalEditarCliente">Editar Cliente</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="formEditarCliente" asp-action="UpdateCliente" asp-controller="Cliente" method="post" class="row g-3">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />

                    <div class="col-md-6">
                        <label asp-for="Identificacion" class="form-label">Identificación</label>
                        <input asp-for="Identificacion" class="form-control" />
                        <span asp-validation-for="Identificacion" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Nombre" class="form-label">Nombre</label>
                        <input asp-for="Nombre" class="form-control" />
                        <span asp-validation-for="Nombre" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Apellido1" class="form-label">Apellido 1</label>
                        <input asp-for="Apellido1" class="form-control" />
                        <span asp-validation-for="Apellido1" class="text-danger"></span>
                    </div>

                    <div class="col-md-6">
                        <label asp-for="Apellido2" class="form-label">Apellido 2</label>
                        <input asp-for="Apellido2" class="form-control" />
                        <span asp-validation-for="Apellido2" class="text-danger"></span>
                    </div>

                    <div class="col-md-12">
                        <label asp-for="Correo" class="form-label">Correo</label>
                        <input asp-for="Correo" type="email" class="form-control" />
                        <span asp-validation-for="Correo" class="text-danger"></span>
                    </div>

                    <div class="col-md-12">
                        <label class="form-label">Números de Teléfono</label>
                        <div class="input-group mb-2">
                            <input type="text" id="nuevoTelefono" class="form-control" placeholder="Ingrese número de teléfono" />
                            <button type="button" class="btn btn-success" id="btnAgregarTelefono">Agregar</button>
                        </div>
                        <div id="listaTelefonos" class="list-group">
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-primary" id="btnEditarCliente">Editar Cliente</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
