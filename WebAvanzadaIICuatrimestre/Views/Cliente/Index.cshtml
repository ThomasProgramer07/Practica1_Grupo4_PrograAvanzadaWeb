@{
    ViewData["Title"] = "Mantenimiento de Clientes";
}

<link rel="stylesheet" href="~/css/cliente.css" asp-append-version="true" />

<div class="container my-4">
    <div class="card shadow-sm">
        <div class="card-header d-flex align-items-center justify-content-between">
            <h2 class="mb-0">Lista de Clientes</h2>
            <button type="button" class="btn btn-success" data-bs-toggle="modal" data-bs-target="#modalCrearCliente">
                Crear Cliente
            </button>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table id="tblCliente" class="table table-hover table-bordered align-middle" style="width:100%">
                    <thead class="table-light">
                        <tr>
                            <th style="width:6%">Id</th>
                            <th>Identificación</th>
                            <th>Nombre</th>
                            <th>Apellido 1</th>
                            <th>Apellido 2</th>
                            <th>Correo</th>
                            <th>Teléfonos</th>
                            <th style="width:18%">Acciones</th>
                        </tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
        </div>
    </div>

    @await Html.PartialAsync("_Editar")
    @await Html.PartialAsync("_Crear")
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/cliente.js" asp-append-version="true"></script>
}